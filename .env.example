# OSInt Location Monitor – Environment Variables
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# WICHTIG: .env.local niemals in Git committen!

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── News APIs ─────────────────────────────────────────────
GNEWS_API_KEY=your-gnews-api-key

# ── SvelteKit (öffentliche Variablen – Prefix PUBLIC_) ────
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Produktions-URL der App – wird für Auth-E-Mail-Redirects genutzt.
# MUSS mit der "Site URL" im Supabase Dashboard übereinstimmen!
# Lokal (.env.local):  http://localhost:5173
# Produktion (Vercel): https://deine-app.vercel.app
PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Optional ──────────────────────────────────────────────
# OPENWEATHER_API_KEY=your-openweathermap-key  # Fallback zu Open-Meteo

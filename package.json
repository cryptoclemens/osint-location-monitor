{
  "name": "osint-location-monitor",
  "version": "0.10.0",
  "private": false,
  "description": "PWA to monitor public information at European locations and send Telegram alerts for critical events.",
  "author": "Clemens Pompeÿ",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
